// StrataHub — Australia-Wide Apartment Management System

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum AustralianState {
  NSW
  VIC
  QLD
  SA
  WA
  TAS
  NT
  ACT
}

enum UserRole {
  SUPER_ADMIN
  BUILDING_MANAGER
  RECEPTION
  OWNER
  TENANT
}

enum UnitType {
  APARTMENT
  STUDIO
  PENTHOUSE
  TOWNHOUSE
  COMMERCIAL
  STORAGE
  PARKING
}

enum RentFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

enum BondStatus {
  PENDING
  LODGED
  PARTIALLY_RELEASED
  FULLY_RELEASED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  WAIVED
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  STRUCTURAL
  APPLIANCE
  PEST_CONTROL
  CLEANING
  SECURITY
  LIFT
  COMMON_AREA
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  SUBMITTED
  ACKNOWLEDGED
  IN_PROGRESS
  AWAITING_PARTS
  SCHEDULED
  COMPLETED
  CLOSED
  CANCELLED
}

enum VisitPurpose {
  PERSONAL
  DELIVERY
  TRADESPERSON
  REAL_ESTATE
  INSPECTION
  OTHER
}

enum ParcelStatus {
  RECEIVED
  NOTIFIED
  COLLECTED
  RETURNED
}

enum KeyType {
  PHYSICAL_KEY
  FOB
  ACCESS_CODE
  REMOTE
  SWIPE_CARD
}

enum AnnouncementScope {
  BUILDING
  FLOOR
  ALL_BUILDINGS
}

enum DocCategory {
  LEASE_AGREEMENT
  BUILDING_RULES
  STRATA_MINUTES
  FINANCIAL_REPORT
  INSURANCE
  COMPLIANCE
  NOTICE
  OTHER
}

enum LevyType {
  ADMIN_FUND
  CAPITAL_WORKS
  SPECIAL_LEVY
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum NotificationType {
  LEVY_CREATED
  MAINTENANCE_STATUS_UPDATED
  MAINTENANCE_CREATED
  ANNOUNCEMENT_PUBLISHED
  PARCEL_RECEIVED
  INVITE_SENT
}

// ============================================================
// IDENTITY & ACCESS
// ============================================================

model Organisation {
  id        String          @id @default(cuid())
  name      String
  abn       String?         @unique
  state     AustralianState
  logoUrl   String?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  buildings Building[]
  members   OrganisationMembership[]

  @@map("organisations")
}

model User {
  id             String   @id @default(cuid())
  supabaseAuthId String   @unique
  email          String   @unique
  firstName      String
  lastName       String
  phone          String?
  avatarUrl      String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orgMemberships      OrganisationMembership[]
  buildingAssignments BuildingAssignment[]
  ownerships          Ownership[]
  tenancies           Tenancy[]
  emergencyContacts   EmergencyContact[]
  maintenanceRequests MaintenanceRequest[]   @relation("requestedBy")
  sentMessages        Message[]              @relation("sender")
  receivedMessages    Message[]              @relation("recipient")
  visitorEntries      VisitorEntry[]         @relation("registeredBy")
  parcelEntries       Parcel[]               @relation("loggedBy")
  announcements       Announcement[]         @relation("author")
  documents           Document[]             @relation("uploadedBy")
  keyLogs             KeyLog[]               @relation("performedBy")
  maintenanceComments MaintenanceComment[]
  notifications       Notification[]

  @@map("users")
}

model OrganisationMembership {
  id             String   @id @default(cuid())
  userId         String
  organisationId String
  role           UserRole
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([userId, organisationId])
  @@map("organisation_memberships")
}

model BuildingAssignment {
  id         String   @id @default(cuid())
  userId     String
  buildingId String
  role       UserRole
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([userId, buildingId, role])
  @@map("building_assignments")
}

model EmergencyContact {
  id           String @id @default(cuid())
  userId       String
  name         String
  relationship String
  phone        String
  email        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

model Invitation {
  id             String   @id @default(cuid())
  email          String
  organisationId String
  buildingId     String?
  unitId         String?
  role           UserRole
  token          String   @unique @default(cuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())

  @@map("invitations")
}

// ============================================================
// PROPERTY STRUCTURE
// ============================================================

model Building {
  id               String          @id @default(cuid())
  organisationId   String
  name             String
  address          String
  suburb           String
  state            AustralianState
  postcode         String
  totalFloors      Int
  totalUnits       Int
  strataSchemeNo   String?
  buildingImageUrl String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  organisation  Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  units         Unit[]
  floors        Floor[]
  commonAreas   CommonArea[]
  assignments   BuildingAssignment[]
  announcements Announcement[]
  documents     Document[]
  strataInfo    StrataInfo?
  financials    FinancialRecord[]
  visitors      VisitorEntry[]
  parcels       Parcel[]
  keyRecords    KeyRecord[]

  @@map("buildings")
}

model Floor {
  id         String  @id @default(cuid())
  buildingId String
  number     Int
  label      String?

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  units    Unit[]

  @@unique([buildingId, number])
  @@map("floors")
}

model Unit {
  id              String   @id @default(cuid())
  buildingId      String
  floorId         String?
  unitNumber      String
  unitType        UnitType @default(APARTMENT)
  bedrooms        Int?
  bathrooms       Int?
  parkingSpaces   Int      @default(0)
  storageSpaces   Int      @default(0)
  squareMetres    Float?
  isOccupied      Boolean  @default(false)
  lotNumber       String?
  unitEntitlement Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  building        Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor           Floor?             @relation(fields: [floorId], references: [id])
  ownerships      Ownership[]
  tenancies       Tenancy[]
  maintenanceReqs MaintenanceRequest[]
  keyRecords      KeyRecord[]
  parkingSpots    ParkingSpot[]
  storageUnits    StorageUnit[]

  @@unique([buildingId, unitNumber])
  @@map("units")
}

model ParkingSpot {
  id     String  @id @default(cuid())
  unitId String
  label  String
  level  String?

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("parking_spots")
}

model StorageUnit {
  id     String @id @default(cuid())
  unitId String
  label  String

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("storage_units")
}

model CommonArea {
  id         String  @id @default(cuid())
  buildingId String
  name       String
  floor      Int?
  notes      String?

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@map("common_areas")
}

// ============================================================
// RESIDENCY & LEASING
// ============================================================

model Ownership {
  id           String    @id @default(cuid())
  userId       String
  unitId       String
  purchaseDate DateTime?
  isPrimary    Boolean   @default(true)
  ownershipPct Float     @default(100)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([userId, unitId])
  @@map("ownerships")
}

model Tenancy {
  id              String        @id @default(cuid())
  userId          String
  unitId          String
  leaseStartDate  DateTime
  leaseEndDate    DateTime?
  rentAmountCents Int
  rentFrequency   RentFrequency
  bondAmountCents Int
  bondStatus      BondStatus    @default(PENDING)
  bondReference   String?
  isActive        Boolean       @default(true)
  moveInDate      DateTime?
  moveOutDate     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  rentPayments RentPayment[]
  bondRecord   BondRecord?

  @@map("tenancies")
}

model BondRecord {
  id                 String          @id @default(cuid())
  tenancyId          String          @unique
  amountCents        Int
  lodgementDate      DateTime?
  lodgementAuthority String
  referenceNumber    String?
  status             BondStatus
  state              AustralianState
  lodgementDeadline  DateTime
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  tenancy Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  @@map("bond_records")
}

// ============================================================
// RENT TRACKING
// ============================================================

model RentPayment {
  id            String        @id @default(cuid())
  tenancyId     String
  amountCents   Int
  dueDate       DateTime
  paidDate      DateTime?
  status        PaymentStatus @default(PENDING)
  paymentMethod String?
  receiptUrl    String?
  notes         String?
  createdAt     DateTime      @default(now())

  tenancy Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  @@map("rent_payments")
}

// ============================================================
// MAINTENANCE
// ============================================================

model MaintenanceRequest {
  id             String              @id @default(cuid())
  unitId         String
  requestedById  String
  title          String
  description    String
  category       MaintenanceCategory
  priority       Priority            @default(MEDIUM)
  status         MaintenanceStatus   @default(SUBMITTED)
  assignedTo     String?
  scheduledDate  DateTime?
  completedDate  DateTime?
  estimatedCost  Int?
  actualCost     Int?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  unit        Unit                 @relation(fields: [unitId], references: [id], onDelete: Cascade)
  requestedBy User                 @relation("requestedBy", fields: [requestedById], references: [id])
  images      MaintenanceImage[]
  comments    MaintenanceComment[]

  @@map("maintenance_requests")
}

model MaintenanceImage {
  id                   String   @id @default(cuid())
  maintenanceRequestId String
  imageUrl             String   // holds storagePath; signed URL is generated server-side on getById
  storagePath          String?  // explicit field for storage operations (delete)
  caption              String?
  createdAt            DateTime @default(now())

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)

  @@map("maintenance_images")
}

model MaintenanceComment {
  id                   String   @id @default(cuid())
  maintenanceRequestId String
  userId               String
  content              String
  createdAt            DateTime @default(now())

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id])

  @@map("maintenance_comments")
}

// ============================================================
// VISITOR MANAGEMENT
// ============================================================

model VisitorEntry {
  id                   String       @id @default(cuid())
  buildingId           String
  registeredById       String
  visitorName          String
  visitorPhone         String?
  visitorCompany       String?
  purpose              VisitPurpose
  unitToVisit          String?
  preApproved          Boolean      @default(false)
  arrivalTime          DateTime?
  departureTime        DateTime?
  vehiclePlate         String?
  deliveryInstructions String?
  notes                String?
  createdAt            DateTime     @default(now())

  building     Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  registeredBy User     @relation("registeredBy", fields: [registeredById], references: [id])

  @@map("visitor_entries")
}

// ============================================================
// PARCEL TRACKING
// ============================================================

model Parcel {
  id              String       @id @default(cuid())
  buildingId      String
  unitNumber      String
  recipientName   String
  carrier         String?
  trackingNumber  String?
  loggedById      String
  loggedAt        DateTime     @default(now())
  collectedAt     DateTime?
  collectedBy     String?
  status          ParcelStatus @default(RECEIVED)
  storageLocation String?
  notes           String?

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  loggedBy User     @relation("loggedBy", fields: [loggedById], references: [id])

  @@map("parcels")
}

// ============================================================
// KEY / ACCESS CODE MANAGEMENT
// ============================================================

model KeyRecord {
  id           String    @id @default(cuid())
  buildingId   String
  unitId       String?
  keyType      KeyType
  identifier   String
  issuedTo     String?
  issuedDate   DateTime?
  returnedDate DateTime?
  isActive     Boolean   @default(true)
  rotationDue  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id])
  logs     KeyLog[]

  @@map("key_records")
}

model KeyLog {
  id            String   @id @default(cuid())
  keyRecordId   String
  action        String
  performedById String
  timestamp     DateTime @default(now())
  notes         String?

  keyRecord   KeyRecord @relation(fields: [keyRecordId], references: [id], onDelete: Cascade)
  performedBy User      @relation("performedBy", fields: [performedById], references: [id])

  @@map("key_logs")
}

// ============================================================
// COMMUNICATION
// ============================================================

model Announcement {
  id           String            @id @default(cuid())
  buildingId   String
  authorId     String
  title        String
  content      String
  priority     Priority          @default(MEDIUM)
  scope        AnnouncementScope @default(BUILDING)
  targetFloors Int[]
  publishedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime          @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  author   User     @relation("author", fields: [authorId], references: [id])

  @@map("announcements")
}

model Document {
  id           String      @id @default(cuid())
  buildingId   String?
  uploadedById String
  title        String
  description  String?
  category     DocCategory
  fileUrl      String
  storagePath  String?
  fileSize     Int
  mimeType     String
  isPublic     Boolean     @default(false)
  tenancyId    String?
  createdAt    DateTime    @default(now())

  building   Building? @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation("uploadedBy", fields: [uploadedById], references: [id])

  @@map("documents")
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  subject     String?
  content     String
  isRead      Boolean  @default(false)
  threadId    String?
  createdAt   DateTime @default(now())

  sender    User @relation("sender", fields: [senderId], references: [id])
  recipient User @relation("recipient", fields: [recipientId], references: [id])

  @@index([threadId])
  @@map("messages")
}

// ============================================================
// STRATA MANAGEMENT
// ============================================================

model StrataInfo {
  id                  String    @id @default(cuid())
  buildingId          String    @unique
  strataPlanNumber    String
  strataManagerName   String?
  strataManagerEmail  String?
  strataManagerPhone  String?
  adminFundBalance    Int?
  capitalWorksBalance Int?
  insurancePolicyNo   String?
  insuranceExpiry     DateTime?
  nextAgmDate         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  building Building      @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  levies   StrataLevy[]
  bylaws   StrataBylaw[]
  meetings StrataMeeting[]

  @@map("strata_info")
}

model StrataLevy {
  id           String        @id @default(cuid())
  strataInfoId String
  unitId       String
  levyType     LevyType
  amountCents  Int
  quarterStart DateTime
  dueDate      DateTime
  paidDate     DateTime?
  status       PaymentStatus @default(PENDING)
  createdAt    DateTime      @default(now())

  strataInfo StrataInfo @relation(fields: [strataInfoId], references: [id], onDelete: Cascade)

  @@map("strata_levies")
}

model StrataBylaw {
  id            String   @id @default(cuid())
  strataInfoId  String
  title         String
  content       String
  bylawNumber   Int
  effectiveDate DateTime
  createdAt     DateTime @default(now())

  strataInfo StrataInfo @relation(fields: [strataInfoId], references: [id], onDelete: Cascade)

  @@map("strata_bylaws")
}

model StrataMeeting {
  id           String   @id @default(cuid())
  strataInfoId String
  title        String
  meetingDate  DateTime
  location     String?
  agendaUrl    String?
  minutesUrl   String?
  notes        String?
  createdAt    DateTime @default(now())

  strataInfo StrataInfo @relation(fields: [strataInfoId], references: [id], onDelete: Cascade)

  @@map("strata_meetings")
}

// ============================================================
// FINANCIALS
// ============================================================

model FinancialRecord {
  id          String        @id @default(cuid())
  buildingId  String
  type        FinancialType
  category    String
  description String
  amountCents Int
  date        DateTime
  receiptUrl  String?
  createdAt   DateTime      @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@map("financial_records")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}
